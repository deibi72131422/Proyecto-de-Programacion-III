<UserControl x:Class="proyectodeloschikis.UcHanoi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:proyectodeloschikis"
             mc:Ignorable="d" 
             >
    <Grid>
        <StackPanel>
            <!-- Cabecera -->
            <TextBlock Text="13. Torres de Hanói" 
                   Foreground="#C084FC" 
                   FontSize="26" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <!-- Controles superiores -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="Número de discos:" Foreground="#A78BFA" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="cmbDiscos" Width="80" Height="35" SelectedIndex="2" FontSize="16">
                    <ComboBoxItem>3</ComboBoxItem>
                    <ComboBoxItem>4</ComboBoxItem>
                    <ComboBoxItem>5</ComboBoxItem>
                    <ComboBoxItem>6</ComboBoxItem>
                    <ComboBoxItem>7</ComboBoxItem>
                    <ComboBoxItem>8</ComboBoxItem>
                </ComboBox>

                <Button Content="Iniciar / Reiniciar" Click="BtnIniciar_Click" 
                    Width="160" Height="38" Margin="30,0,0,0"
                    Background="#C084FC" Foreground="#1A1A2E" FontWeight="Bold"/>

                <Button Content="Resolver Automático" Click="BtnResolver_Click" 
                    Width="160" Height="38" Margin="15,0,0,0"
                    Background="#22C55E" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
            <StackPanel>
            <TextBlock Text="Velocidad:" 
                Foreground="#A78BFA" 
                FontSize="16" 
                VerticalAlignment="Center"
                Margin="0,0,10,0"/>
            <Slider x:Name="sliderVelocidad"
             Width="200"
             Minimum="10"
             Maximum="1000"
             Value="150"
             TickFrequency="50"
             IsSnapToTickEnabled="True"/>

            <TextBlock x:Name="txtVelocidad"
                Text="150 ms"
                Foreground="White"
                Margin="10,0,0,0"
                VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Las 3 Torres -->
            <Grid Height="320" HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <!-- Torre A (Origen) -->
                <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <TextBlock Text="A (Origen)" Foreground="#A78BFA" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Canvas x:Name="canvasA" Width="180" Height="280" Background="#1F1F3A" ClipToBounds="True"/>
                </StackPanel>

                <!-- Torre B (Auxiliar) -->
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <TextBlock Text="B (Auxiliar)" Foreground="#A78BFA" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Canvas x:Name="canvasB" Width="180" Height="280" Background="#1F1F3A" ClipToBounds="True"/>
                </StackPanel>

                <!-- Torre C (Destino) -->
                <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center">
                    <TextBlock Text="C (Destino)" Foreground="#A78BFA" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <Canvas x:Name="canvasC" Width="180" Height="280" Background="#1F1F3A" ClipToBounds="True"/>
                </StackPanel>
            </Grid>

            <!-- Lista de movimientos -->
            <TextBlock Text="Movimientos:" Foreground="#C084FC" FontSize="16" Margin="0,20,0,8"/>
            <TextBlock x:Name="txtContador"
           Text="Movimientos: 0"
           Foreground="#22C55E"
           FontSize="16"
           Margin="0,0,0,10"/>
            <ListBox x:Name="lstMovimientos" Height="180" Background="#0F0F1E" Foreground="#E0E0FF" 
                 FontSize="15" BorderBrush="#C084FC"/>
        </StackPanel>
    </Grid>
</UserControl>
