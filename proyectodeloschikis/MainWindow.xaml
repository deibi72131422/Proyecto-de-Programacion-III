<Window x:Class="proyectodeloschikis.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:proyectodeloschikis"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <Border Background="#1A1A2E" Grid.Column="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Background="Transparent">

                <StackPanel Margin="10">


                    <TextBlock Text="DATA LAB"
                       Foreground="#C084FC"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="10"
                       HorizontalAlignment="Center"/>

                    <Separator Margin="5" Background="#C084FC"/>


                    <Button Style="{StaticResource MenuButton}" Content="Ordenamiento y Búsqueda" Click="Ordenamiento_Click"/>


                    <ToggleButton x:Name="btnLineales" 
                          Style="{StaticResource MenuToggleButton}" 
                          Content="Estructuras Lineales"
                          Checked="BtnLineales_Checked"
                          Unchecked="BtnLineales_Unchecked"/>

                    <StackPanel x:Name="panelLineales" Visibility="Collapsed" Margin="10,0,0,0">
                        <Button Style="{StaticResource MenuButton}" Content="Listas" Click="Listas_Click" />
                        <Button Style="{StaticResource MenuButton}" Content="Listas Doble" Click="LidstasDoblementeEnlazadas_Click"/>
                        <Button Style="{StaticResource MenuButton}" Content="Colas" Click="Colas_Click"/>
                        <Button Style="{StaticResource MenuButton}" Content="Pilas" Click="Pilas_Click"/>
                    </StackPanel>


                    <ToggleButton x:Name="btnNoLineales" 
                          Style="{StaticResource MenuToggleButton}" 
                          Content="Estructuras No Lineales"
                          Checked="BtnNoLineales_Checked"
                          Unchecked="BtnNoLineales_Unchecked"/>

                    <StackPanel x:Name="panelNoLineales" Visibility="Collapsed" Margin="10,0,0,0">
                        <Button Style="{StaticResource MenuButton}" Content="Árboles" Click="Arbol_Click"/>
                        <Button Style="{StaticResource MenuButton}" Content="Grafos" Click="Grafos_Click"/>
                    </StackPanel>


                    <Button Style="{StaticResource MenuButton}" Content="Calculadora (Pilas)" Click="Calculadora_Click"/>
                    <Button Style="{StaticResource MenuButton}" Content="Recursividad" Click="Recursivo_Click" />

                </StackPanel>
            </ScrollViewer>
        </Border>


        <Grid Grid.Column="1">
            <Border Background="#121225" CornerRadius="10" Margin="10" >
                <ContentControl x:Name="MainContent"/>
            </Border>
        </Grid>

    </Grid>
</Window>
