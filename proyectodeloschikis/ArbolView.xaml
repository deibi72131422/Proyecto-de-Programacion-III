<UserControl x:Class="proyectodeloschikis.ArbolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:proyectodeloschikis"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="15">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- 🔹 PANEL IZQUIERDO -->
        <ScrollViewer Grid.Column="0"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <TextBlock Text="Árbol Binario"
           FontSize="22"
           Foreground="#C084FC"
           Margin="0,0,0,10"/>

                <!-- INPUT -->
                <TextBox x:Name="txtValor" Background="#1A1A2E"
                     Foreground="White"
                     BorderBrush="#C084FC" Height="35" FontSize="30"/>
                <StackPanel Orientation="Horizontal" Margin="5">

                    <RadioButton x:Name="rbEnteros"
             Content="Enteros"
             Foreground="White"
             FontSize="16"
             GroupName="TipoDato"
             Margin="10,0"
             IsChecked="True"/>

                    <RadioButton x:Name="rbCaracteres"
             Content="Caracteres"
             Foreground="White"
             FontSize="16"
             GroupName="TipoDato"
             Margin="10,0"/>

                </StackPanel>

                <!-- INSERCIÓN -->
                <Label Content="Inserccion y eliminacion " Foreground="White" Margin="10,10,0,5"/>
                <WrapPanel>
                    <Button Content="Insertar" Style="{StaticResource MenuButton}"  Click="Insertar_Click"/>
                    <Button Content="Eliminar" Style="{StaticResource MenuButton}" />
                </WrapPanel>

                <!-- BÚSQUEDA -->
                <Label Content="Búsqueda y Recuperación de Datos " Foreground="White" Margin="10,10,0,5"/>
                <WrapPanel>
                    <Button Content="Buscar" Style="{StaticResource MenuButton}" />
                    <Button Content="Nivel" Style="{StaticResource MenuButton}" />
                </WrapPanel>

                <!-- PROPIEDADES -->
                <Label Content=" Recorridos del Árbol" Foreground="White" Margin="10,10,0,5"/>
                <WrapPanel>
                    <Button Content="Altura" Style="{StaticResource MenuButton}" />
                    <Button Content="Mínimo" Style="{StaticResource MenuButton}" />
                    <Button Content="Máximo" Style="{StaticResource MenuButton}" />
                </WrapPanel>

                <!-- CONTROL -->
                <Label Content="Balanceo del Árbol (Binario)" Foreground="White" Margin="10,10,0,5"/>
                <WrapPanel>
                    <Button Content="Balancear" Style="{StaticResource MenuButton}" />
                    <Button Content="Reiniciar" Style="{StaticResource MenuButton}" />
                </WrapPanel>

                <!-- RECORRIDOS -->
                <TextBlock Text="Recorridos"
           Foreground="White"
           Margin="10,10,0,5"/>

                <WrapPanel>
                    <Button Content="InOrden" Style="{StaticResource MenuButton}" />
                    <Button Content="PreOrden" Style="{StaticResource MenuButton}" />
                    <Button Content="PostOrden" Style="{StaticResource MenuButton}" />
                </WrapPanel>

                <!-- RESULTADO -->
                <TextBox x:Name="txtResultado" Background="#1A1A2E"
                     Foreground="White"
                     BorderBrush="#C084FC" Height="35" FontSize="30"
         IsReadOnly="True"
         Margin="0,10,0,0"/>

            </StackPanel>
        </ScrollViewer>


        <!-- 🔹 CANVAS -->
        <Border Grid.Column="1"
            Background="#1A1A2E"
            BorderBrush="#C084FC"
            BorderThickness="1"
            CornerRadius="10"
            Margin="10">
            <ScrollViewer Grid.Column="1"
          VerticalScrollBarVisibility="Auto"
          HorizontalScrollBarVisibility="auto">
                <Canvas x:Name="canvasArbol"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
