<UserControl x:Class="proyectodeloschikis.RecursivoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:proyectodeloschikis"
             mc:Ignorable="d" 
             >
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Menú lateral -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Grid.Column="0" Margin="15" Background="#0F0F1E">
                <TextBlock Text="PROYECTO 6" Foreground="#C084FC" FontSize="22" FontWeight="Bold" Margin="10,20,10,5" HorizontalAlignment="Center"/>
                <TextBlock Text="Recursividad" Foreground="#A78BFA" FontSize="14" Margin="10,0,10,20" HorizontalAlignment="Center"/>

                <Button Content="1. Número Capicúa" Click="BtnCapicua_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="2. Suma de Vector" Click="BtnSumaVector_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="3. Producto de Vector" Click="BtnProductoVector_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="4. Número Menor del Vector" Click="BtnMenorVector_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="5. Número Mayor del Vector" Click="BtnMayorVector_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="6. Factorial" Click="BtnFactorial_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="7. Fibonacci" Click="BtnFibonacci_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="8. Invertir Número" Click="BtnInvertir_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="9. Suma de Dígitos" Click="BtnSumaDigitos_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="10. Suma 1 hasta N" Click="BtnSuma1hastaN_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="11. Par o Impar" Click="BtnParImpar_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="12. Positivo o Negativo" Click="BtnPosNeg_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
                <Button Content="13. Torres de Hanói" Click="BtnHanoi_Click" Style="{StaticResource MenuButton}" Margin="10,3"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ====================== ÁREA DE TRABAJO ====================== -->
        <Border Grid.Column="1" Margin="30" Background="#1A1A2E" CornerRadius="12" Padding="30">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel VerticalAlignment="Center" MaxWidth="620">

                    <TextBlock x:Name="lblTitulo" 
       Text="Selecciona un algoritmo" 
       Foreground="White" 
       FontSize="28" 
       FontWeight="SemiBold" 
       HorizontalAlignment="Center" 
       Margin="0,0,0,30"/>
                    <ContentControl x:Name="MainContent" />

                    <!-- Entrada para número simple -->
                    <TextBlock x:Name="lblInput" 
       Text="Entrada:" 
       Foreground="#A78BFA" 
       FontSize="15" 
       Margin="0,0,0,8"/>
                    <TextBox x:Name="txtInput" 
     Width="380" 
     Height="50"
     Background="#0F0F1E" 
     Foreground="White" 
     BorderBrush="#C084FC" 
     BorderThickness="2"
     FontSize="18" 
     Padding="15,12"/>

                    <!-- Panel para Vector -->
                    <StackPanel x:Name="panelVector" Visibility="Collapsed">
                        <TextBlock Text="Vector (separado por comas):" 
           Foreground="#A78BFA" 
           FontSize="15" 
           Margin="0,0,0,8"/>
                        <TextBox x:Name="txtVector" 
         Width="380" 
         Height="50"
         Background="#0F0F1E" 
         Foreground="White" 
         BorderBrush="#C084FC" 
         BorderThickness="2"
         FontSize="18" 
         Padding="15,12"
         TextChanged="txtVector_TextChanged"/>

                        <TextBlock Text="Vector ingresado:" 
           Foreground="#A78BFA" 
           FontSize="15" 
           Margin="0,20,0,10"/>

                        <ItemsControl x:Name="lstVectorVisual" HorizontalAlignment="Left">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252540" 
                    Padding="16,10" 
                    Margin="4" 
                    CornerRadius="8">
                                        <TextBlock Text="{Binding}" 
                           Foreground="#E0D4FF" 
                           FontSize="18" 
                           FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Botón Calcular -->
                    <Button Content="Calcular" 
    Click="BtnCalcular_Click" 
    Width="170" 
    Height="48" 
    Margin="0,35,0,0"
    Background="#C084FC" 
    Foreground="#1A1A2E" 
    FontWeight="Bold" 
    FontSize="17"
    Cursor="Hand"/>

                    <!-- Resultado -->
                    <TextBlock x:Name="txtResultado" 
       Text="Resultado: " 
       Foreground="#C084FC" 
       FontSize="26" 
       Margin="0,50,0,0" 
       TextWrapping="Wrap"
       HorizontalAlignment="Center"/>

                </StackPanel>
            </ScrollViewer>

        </Border>
    </Grid>
</UserControl>
