<UserControl x:Class="proyectodeloschikis.CalculadoraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:proyectodeloschikis"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#1A1A2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="White" 
                BorderBrush="Black" 
                BorderThickness="1" 
                Margin="10,20,10,10" 
                Height="70">
            <TextBlock x:Name="txtPantalla" 
                       Text="0" 
                       FontSize="32" 
                       Foreground="Black" 
                       VerticalAlignment="Center" 
                       HorizontalAlignment="Right" 
                       Margin="10,0"/>
        </Border>

        <Grid Grid.Row="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="7" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="0" Grid.Column="1" Content="8" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="0" Grid.Column="2" Content="9" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="0" Grid.Column="3" Content="/" Style="{StaticResource MenuButton}"/>

            <Button Grid.Row="1" Grid.Column="0" Content="4" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="1" Grid.Column="1" Content="5" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="1" Grid.Column="2" Content="6" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="1" Grid.Column="3" Content="*" Style="{StaticResource MenuButton}"/>

            <Button Grid.Row="2" Grid.Column="0" Content="1" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="2" Grid.Column="1" Content="2" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="2" Grid.Column="2" Content="3" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="2" Grid.Column="3" Content="-" Style="{StaticResource MenuButton}"/>

            <Button Grid.Row="3" Grid.Column="0" Content="0" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="3" Grid.Column="1" Content="(" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="3" Grid.Column="2" Content=")" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="3" Grid.Column="3" Content="+" Style="{StaticResource MenuButton}"/>

            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                    Content="Borrar uno" Style="{StaticResource MenuButton}"/>
            <Button Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="2" 
                    Content="=" Style="{StaticResource MenuButton}"/>

            <Button Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
                    Content="Limpiar Todo" Style="{StaticResource MenuButton}"/>
        </Grid>
    </Grid>
</UserControl>
