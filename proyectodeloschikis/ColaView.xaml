<UserControl x:Class="proyectodeloschikis.ColaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:proyectodeloschikis"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- PANEL CONTROLES (izquierda) -->
        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,20,0">
            <StackPanel>

                <TextBlock Text="Cola"
                           FontSize="22"
                           Foreground="#C084FC"
                           Margin="0,0,0,15"
                           HorizontalAlignment="Center"/>

                <!-- Insertar -->
                <DockPanel LastChildFill="True" Margin="0,0,0,16">
                    <TextBox DockPanel.Dock="Left"
                             Width="180"
                             Height="36"
                             Margin="0,0,8,0"
                             Background="#1A1A2E"
                             Foreground="White"
                             BorderBrush="#C084FC"
                             FontSize="16"
                             x:Name="txtInsertar"/>
                    <Button Content="Insertar"
                            Style="{StaticResource MenuButton}"
                            HorizontalAlignment="Left"/>
                </DockPanel>

                <!-- Botones Quitar y Limpiar (abajo del insertar) -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="Quitar"
                            Style="{StaticResource MenuButton}"
                            Width="140"
                            Margin="0,0,12,0"
                            />
                    <Button Content="Limpiar"
                            Style="{StaticResource MenuButton}"
                            Width="140"
                            />
                </StackPanel>

                <!-- ¿Está vacía? -->
                <DockPanel LastChildFill="True" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Left"
                            Content="¿Está vacía?"
                            Style="{StaticResource MenuButton}"
                            Margin="0,0,10,0"
                            />
                    <TextBox Background="#1A1A2E"
                             Foreground="White"
                             BorderBrush="#C084FC"
                             FontSize="16"
                             IsReadOnly="True"
                             x:Name="txtEstaVacia"/>
                </DockPanel>

                <!-- ¿Está llena? -->
                <DockPanel LastChildFill="True" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Left"
                            Content="¿Está llena?"
                            Style="{StaticResource MenuButton}"
                            Margin="0,0,10,0"
                            />
                    <TextBox Background="#1A1A2E"
                             Foreground="White"
                             BorderBrush="#C084FC"
                             FontSize="16"
                             IsReadOnly="True"
                             x:Name="txtEstaLlena"/>
                </DockPanel>

                <!-- Tamaño Máximo -->
                <DockPanel LastChildFill="True" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Left"
                            Content="Tamaño Máximo"
                            Style="{StaticResource MenuButton}"
                            Margin="0,0,10,0"
                            />
                    <TextBox Background="#1A1A2E"
                             Foreground="White"
                             BorderBrush="#C084FC"
                             FontSize="16"
                             IsReadOnly="True"
                             x:Name="txtTamanoMaximo"/>
                </DockPanel>

                <!-- Cima -->
                <DockPanel LastChildFill="True" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Left"
                            Content="Cima"
                            Style="{StaticResource MenuButton}"
                            Margin="0,0,10,0"
                            />
                    <TextBox Background="#1A1A2E"
                             Foreground="White"
                             BorderBrush="#C084FC"
                             FontSize="16"
                             IsReadOnly="True"
                             x:Name="txtCima"/>
                </DockPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- LISTBOX QUE MUESTRA EL RESULTADO DE QUITAR (y posiblemente la estructura completa) -->
        <ScrollViewer Grid.Column="1"
                      Margin="10"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Background="#1A1A2E"
                      BorderBrush="#C084FC"
                      BorderThickness="1">
            <ListBox x:Name="listaDatos"
                     Background="Transparent"
                     Foreground="White"
                     BorderThickness="0"
                     FontSize="16"
                     FontWeight="SemiBold"
                     HorizontalContentAlignment="Center"
                     VerticalContentAlignment="Center"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
        </ScrollViewer>
    </Grid>
</UserControl>
